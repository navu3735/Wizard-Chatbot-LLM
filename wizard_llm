_sequences[:, -1]\n\n'''\nSuppose:\n[\n [0, 0, 5, 8],\n [0, 5, 8, 2],\n [5, 8, 2, 9]\n]\n\nX becomes:\n[\n [0, 0, 5],\n [0, 5, 8],\n [5, 8, 2]\n]\n\nThe model should be able to learn that the output should be:\n[8, 2, 9]\n\n'''\n\nprint(X[:3])\nprint(y[:3])","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["[[   0    0    0 ...    0    0 2350]\n"," [   0    0    0 ...    0 2350   25]\n"," [   0    0    0 ... 2350   25    2]]\n","[25  2  1]\n"]}],"execution_count":14},{"id":"a9dfd0c8-cf91-41c6-855b-c03221e4581f","cell_type":"markdown","source":"The Model","metadata":{}},{"id":"c207d116-2341-41aa-af4e-26e648c725e6","cell_type":"code","source":"from tensorflow.keras.models import Sequential\nfrom tensorflow.keras.layers import Embedding, LSTM, Dense\n\n'''\nEmbedding Layer:\nwizard = 53\ndorothy = 91\n\nTransforms 53 into:\n[0.21, -0.88, 0.55, ...]\n\nEmbeddings are NOT manually programmed.\n\nThe model learns them automatically through training.\n\nThat’s one of the beautiful parts of deep learning.\n\n\nLSTM processes the sequence and eventually produces the contextual understanding of the sequence.\n\n\nDense Layer is the prediction layer, it outputs the score of each possible next word.\n\n\nSoftmax makes the scores become probabilities\n'''","metadata":{},"outputs":[{"data":{"text/plain":["'\\nEmbedding Layer:\\nwizard = 53\\ndorothy = 91\\n\\nTransforms 53 into:\\n[0.21, -0.88, 0.55, ...]\\n\\nEmbeddings are NOT manually programmed.\\n\\nThe model learns them automatically through training.\\n\\nThat’s one of the beautiful parts of deep learning.\\n\\n\\nLSTM processes the sequence and eventually produces the contextual understanding of the sequence.\\n\\n\\nDense Layer is the prediction layer, it outputs the score of each possible next word.\\n\\n\\nSoftmax makes the scores become probabilities\\n'"]},"execution_count":16,"metadata":{},"output_type":"execute_result"}],"execution_count":16},{"id":"e8d90af6-6887-4c66-be75-0569dfdbe107","cel